# SQS Consumer Configuration
QUEUE_URL=https://sqs.us-east-1.amazonaws.com/523566111264/Chatwoot-Meta-Queue
AWS_REGION=us-east-1

# AWS Credentials (if not using AWS CLI profile)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Routing Configuration
DESTINATION_HOST=http://localhost:3001
PHONE_ROUTES=5511999999999::/webhooks/meta::optional-token|5511888888888::/webhooks/whatsapp
# Token is optional - if provided, will be sent as Authorization: Bearer {token}
PHONE_ROUTES=+55 19 9999-9999::/webhooks/whatsapp/+55199999999::secret_token_1|+55 19 88888-8888::/webhooks/whatsapp/+5519888888888

QUEUE_URL=
AWS_REGION=us-east-1
# WhatsApp Cloud API Token (for downloading media)
WHATSAPP_API_TOKEN=YOUR_WHATSAPP_TOKEN_HERE

# Google Cloud Storage Configuration
GCS_BUCKET=jcm-chatwoot
GCS_CREDENTIALS_PATH=/app/gcs-credentials.json
