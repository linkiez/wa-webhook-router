# Comma-separated list of tokens authorized for webhook verification
AUTHORIZED_TOKENS=token1,token2,token3

# Base URL for destination endpoints
DESTINATION_HOST=https://your-domain.com

# Phone number to path mappings
# Format: phone::path|phone::path
# Paths will be appended to DESTINATION_HOST, or use full URLs starting with http/https
PHONE_ROUTES=+55 19 9999-9999::/webhooks/whatsapp/+55199999999|+55 19 88888-8888::/webhooks/whatsapp/+5519888888888